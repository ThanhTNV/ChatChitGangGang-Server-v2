# Copy to .env and load with your tooling (do not commit secrets).
HTTP_ADDR=:8080
LOG_LEVEL=info
LOG_FORMAT=text

# Optional; absolute public base for OpenAPI "servers" + Swagger "Try it out" (no trailing slash).
# If unset: derived from the HTTP request (Host + optional X-Forwarded-Proto / X-Forwarded-Host / X-Forwarded-Prefix).
# Behind TLS ingress with path /api, nginx should send X-Forwarded-Prefix; or set explicitly, e.g.:
# OPENAPI_PUBLIC_BASE_URL=https://localhost/api

# Optional for API server: /ready probes each configured dependency (others report skipped).
# - DATABASE_URL → Postgres ping
# - REDIS_ADDR → Redis PING (client created at startup)
# - KEYCLOAK_READY_URL (if set) → HTTP GET for Keycloak; else KEYCLOAK_ISSUER
# - MINIO_ENDPOINT (+ MINIO_USE_SSL) → GET http(s)://<host>/minio/health/live
# With docker compose: user/pass/db match deploy/docker/init-db.sql
# Host must see Postgres on port 5432: run `docker compose up -d postgres` then `docker compose ps`.
# If you still get "connection refused", nothing is listening on localhost:5432 (compose down,
# wrong port, or another Postgres not running). After DB is up: `make migrate-up`.
DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/internal_comm?sslmode=disable

# Redis (compose service `redis`, default port 6379). Unset to skip Redis on /ready.
REDIS_ADDR=localhost:6379

# MinIO S3 API + console (compose defaults; change in production). Unset to skip MinIO on /ready.
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minio
MINIO_SECRET_KEY=minioadmin
MINIO_USE_SSL=false

# Keycloak — leave KEYCLOAK_ISSUER empty to disable /v1 auth routes (health/ready only).
# When issuer is set, KEYCLOAK_AUDIENCE is required and DATABASE_URL must be set (user upsert).
# KEYCLOAK_AUDIENCE: resource "aud" OR public client id in "azp" (see docs/keycloak-flutter.md).
# Issuer must match JWT "iss". Direct Keycloak :8090 uses /realms/... at root; ingress uses https://host/oauth/realms/...
KEYCLOAK_ISSUER=http://localhost:8090/realms/your-realm
# KEYCLOAK_ISSUER=https://localhost/oauth/realms/your-realm
# Optional; use when API runs in Docker but issuer is host URL. Keycloak 26: health is on management port 9000 (not 8080).
# KEYCLOAK_READY_URL=http://keycloak:9000/health/ready
KEYCLOAK_AUDIENCE=internal-comm-api
# Optional; defaults to {issuer}/protocol/openid-connect/certs
KEYCLOAK_JWKS_URL=http://localhost:8090/realms/your-realm/protocol/openid-connect/certs
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin
